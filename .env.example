# Optional compatibility aliases
REACT_APP_SHOPIFY_DOMAIN=backlog-5.myshopify.com
REACT_APP_SHOPIFY_STOREFRONT_TOKEN=22a4676d6f225af8ba19781367e02705
# Set this to your Shopify metaobject definition type, not the field type.
# For the screenshot shown, try the definition handle for "World-Image" first.
REACT_APP_SHOPIFY_WORLD_METAOBJECT_TYPE=world_image
# Landing hero video definition handle.
REACT_APP_SHOPIFY_LANDING_VIDEO_METAOBJECT_TYPE=LandingPageVideo
# Landing page image definition handle.
